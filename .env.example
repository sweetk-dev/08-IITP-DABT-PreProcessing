# =====================================================
# 08-IITP-DABT-PreProcessing 환경 설정 예시
# 이 파일을 .env 로 복사 후 값을 채워 주세요.
#   cp .env.example .env
# =====================================================

# ---------------------------------------------------------
# [DB 연결 설정]
# ---------------------------------------------------------
# 필수 | PostgreSQL 접속 URL
# 형식: postgresql://user:password@host:port/dbname
DB_URL=postgresql://username:password@localhost:5432/iitp_dabt

# 선택 | DB 배치 삽입 크기 (기본값: 100)
DB_BATCH_SIZE=100

# ---------------------------------------------------------
# [로깅 설정]
# ---------------------------------------------------------
# 선택 | 로그 출력 레벨 (DEBUG / INFO / WARNING / ERROR)
# 기본값: INFO
LOG_LEVEL=INFO

# ---------------------------------------------------------
# [외부 시스템 / KOSIS API 설정]
# ---------------------------------------------------------
# 선택 | 수집 대상 외부 시스템 식별자 (이슈 #29, v1.5.0~)
# CLI --ext-sys 가 지정되면 그 값이 우선. 둘 다 없으면 default 'KOSIS'.
# 가능값 예: KOSIS / DATA_GO_KR / MICRODATA (sys_ext_api_info 등록 분만 가능)
EXT_SYS=KOSIS

# 선택 | KOSIS 시스템 구분 코드 (기본값: KOSIS) — 레거시 호환용
EXT_API_INFO_KOSIS_SYS=KOSIS


# ---------------------------------------------------------
# [병렬처리 성능 설정]
# ---------------------------------------------------------
# 선택 | 파일 저장 병렬 워커 수 (기본값: 4)
PARALLEL_WORKERS_FILE=4

# 선택 | DB 삽입 병렬 워커 수 (기본값: 2)
PARALLEL_WORKERS_DB=2

# ---------------------------------------------------------
# [데이터 수집 옵션]
# ---------------------------------------------------------
# 선택 | 데이터 수집 범위 (ALL / PARTIAL, 기본값: ALL)
DATA_COLLECTION_SCOPE=ALL

# 선택 | KOSIS 최신 변경일 기준 업데이트 여부 (ON / OFF)
# ON : 최종 변경일이 내부 기록보다 최신인 경우에만 DB 업데이트
# OFF: 항상 DB 업데이트 (기본값)
CHECK_DATA_LATEST_DATE_MODE=OFF


# ---------------------------------------------------------
# [이동편의 소스 설정] (이슈 #76, v1.7.0~)
# ext_sys: GBIS / KORAIL_CONV / KOWSI_FACL / TOUR_BF_API
# 인증키 우선순위: sys_ext_api_info.auth > <EXT_SYS>_API_KEY > DATA_GO_KR_API_KEY
# ---------------------------------------------------------
# 공공데이터포털 공통 인증키 (계정당 1개, 서비스별 활용신청 필요)
DATA_GO_KR_API_KEY=

# GBIS(경기버스정보) — tran_bus_route_info 적재
# GBIS_BASE_URL=https://apis.data.go.kr/6410000
# 노선 필터(regionName 부분일치, 기본: 안양)
# GBIS_REGION_FILTER=안양

# 한국철도공사 편의시설정보 — poi_station_access_status 적재
# KORAIL_CONV_BASE_URL=https://apis.data.go.kr/B551457/convenience
# KORAIL_PAGE_SIZE=500

# 한국사회보장정보원 장애인편의시설 — poi_facility_accessibility 적재
# KOWSI_FACL_BASE_URL=https://apis.data.go.kr/B554287/DisabledPersonConvenientFacility
# KOWSI_ADDR_FILTER=안양시
# KOWSI_PAGE_SIZE=1000 (API 상한 1000 — 초과 시 파라미터 오류)
# 실행당 스캔 페이지 수(일 트래픽 한도 방어, 이어받기는 state.json)
# KOWSI_MAX_PAGES=80
# 전 페이지 완주 후 재스캔 대기 일수
# KOWSI_RESCAN_DAYS=28
# 분할 수집 상태 파일 경로
# KOWSI_STATE_PATH=ext_data/KOWSI_FACL/state.json
# 기구표 상세 호출 여부(트래픽 한도 주의, 기본 OFF)
# KOWSI_FETCH_EVAL=OFF

# 한국관광공사 무장애여행 — poi_tour_bf_facility 적재
# TOUR_BF_API_BASE_URL=https://apis.data.go.kr/B551011/KorWithService2
# TOUR_AREA_CODE=31
# TOUR_SIGUNGU_CODE=17
