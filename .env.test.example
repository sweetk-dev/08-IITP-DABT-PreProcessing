# =============================================================================
# .env.test.example — 검증용 테스트 서버 환경변수 템플릿
# =============================================================================
# 사용법:
#   cp .env.test.example .env
#   # 그 다음 < > 로 표시된 자리표시자를 실제 값으로 채워주세요.
#
# 본 템플릿은 운영용 .env.example 과 분리되어 있습니다.
# 검증용 테스트 서버에서만 사용하며, 운영 환경에서는 사용하지 마세요.
# =============================================================================


# -----------------------------------------------------------------------------
# [DB 연결 설정 — 검증용 DB]
# -----------------------------------------------------------------------------
# 필수 | 검증용 PostgreSQL 접속 URL
# 형식: postgresql://<user>:<password>@<host>:<port>/<dbname>
# - <user>     : 검증용 DB 앱 사용자 (예: iitp_app — docs/testing/local-setup.md §1-2)
# - <password> : 위 사용자의 비밀번호
# - <host>     : 127.0.0.1 (검증용 테스트 서버 내부)
# - <port>     : 5432 (PostgreSQL 기본)
# - <dbname>   : 검증용 데이터베이스 이름 (예: iitp_practice)
DB_URL=postgresql://iitp_app:<APP_DB_PASSWORD>@127.0.0.1:5432/<TEST_DB>

# 선택 | DB 배치 삽입 크기 (검증 시 작게 시작 권장)
DB_BATCH_SIZE=100


# -----------------------------------------------------------------------------
# [로깅]
# -----------------------------------------------------------------------------
# 선택 | 로그 출력 레벨 (DEBUG / INFO / WARNING / ERROR)
# 검증 시 자세한 흐름을 보려면 DEBUG, 운영처럼 보려면 INFO.
LOG_LEVEL=DEBUG


# -----------------------------------------------------------------------------
# [외부 시스템 / KOSIS API]
# -----------------------------------------------------------------------------
# 선택 | 수집 대상 외부 시스템 식별자
# CLI --ext-sys 가 지정되면 그 값이 우선. 둘 다 없으면 default 'KOSIS'.
# 가능값: KOSIS / DATA_GO_KR / MICRODATA ... (sys_ext_api_info 등록 분만 가능)
EXT_SYS=KOSIS

# 선택 | KOSIS 시스템 구분 코드 (레거시 호환용, 기본값: KOSIS)
EXT_API_INFO_KOSIS_SYS=KOSIS

# 선택 | KOSIS API 1회 최대 조회 건수 (기본값: 40000)
# 검증 단계에서는 작은 값으로 빠르게 확인 가능
MAX_KOSIS_API_GET_DATA_CNT=1000


# -----------------------------------------------------------------------------
# [병렬처리 성능 설정 — 검증 단계는 보수적으로]
# -----------------------------------------------------------------------------
# 선택 | 파일 저장 병렬 워커 수 (기본값: 4, 검증 권장: 2)
PARALLEL_WORKERS_FILE=2

# 선택 | DB 삽입 병렬 워커 수 (기본값: 2, 검증 권장: 1)
PARALLEL_WORKERS_DB=1


# -----------------------------------------------------------------------------
# [데이터 수집 옵션]
# -----------------------------------------------------------------------------
# 선택 | 데이터 수집 범위 (ALL / PARTIAL, 기본값: ALL)
# 검증 단계는 PARTIAL 로 일부 통계표만 수집하는 것을 권장 (시간 단축).
DATA_COLLECTION_SCOPE=PARTIAL

# 선택 | KOSIS 최신 변경일 기준 업데이트 여부 (ON / OFF)
# ON : 최종 변경일이 내부 기록보다 최신인 경우에만 DB 업데이트
# OFF: 항상 DB 업데이트 (검증 시 기본)
CHECK_DATA_LATEST_DATE_MODE=OFF


# -----------------------------------------------------------------------------
# [PARTIAL 수집 시 대상 통계표 ID 목록]
# -----------------------------------------------------------------------------
# DATA_COLLECTION_SCOPE=PARTIAL 일 때만 사용.
# 한 줄에 하나씩, sys_stats_src_api_info 에 등록된 통계표 ID 를 기재.
# 검증용으로 가벼운 1~2개로 시작 권장.
[TARGET_SRC_TBL_ID_LIST]
DT_117102_A047
# DT_112014_2023_01_135
